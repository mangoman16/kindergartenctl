# Root .htaccess - Routes all requests to public/ directory
#
# IMPORTANT FOR SHARED/MANAGED HOSTING:
# If you get a 403 Forbidden error, you have two options:
# 1. Set your DocumentRoot to point to the "public/" subdirectory (recommended)
# 2. Or delete this .htaccess file and move the contents of public/
#    directly into your web root (public_html), keeping src/, storage/, etc.
#    one level ABOVE your web root for security.

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Route all requests to public directory
    RewriteRule ^$ public/ [L]
    RewriteRule (.*) public/$1 [L]
</IfModule>

# Deny access to hidden files (like .env, .git, etc.)
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Deny access to sensitive file types in root
<FilesMatch "\.(lock|md|json|sql|log)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
